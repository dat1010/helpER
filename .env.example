# Core polling
OPENCLAW_POLL_SECONDS=60
OPENCLAW_LOG_LEVEL=INFO

# Plane connection
PLANE_BASE_URL=http://localhost:8085
PLANE_API_TOKEN=replace-me
PLANE_WORKSPACE_SLUG=your-workspace
PLANE_PROJECT_IDS=project-uuid-1,project-uuid-2

# Workflow state names in Plane
PLANE_STATE_PLANNING=Planning
PLANE_STATE_PLANNED=Planned
PLANE_STATE_IMPLEMENT=Implement
PLANE_STATE_REVIEW=Review

# Workflow labels in Plane
PLANE_LABEL_NEEDS_PLAN=needs-plan
PLANE_LABEL_READY_FOR_IMPL=ready-for-openclaw

# GitHub auth and default repo fallback
GITHUB_TOKEN=replace-me
GITHUB_DEFAULT_REPO=owner/repo

# Map Plane project UUID to GitHub repo (JSON)
# Example: {"project-uuid-1":"owner/repo-a","project-uuid-2":"owner/repo-b"}
PROJECT_REPO_MAP={}

# Homepage links generated by scripts/render-homepage-config.sh
HOMEPAGE_PLANE_URL=http://localhost:8085
HOMEPAGE_GITHUB_URL=https://github.com
HOMEPAGE_OPENCLAW_URL=http://localhost:8081
